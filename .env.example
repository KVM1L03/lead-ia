# LeadForge — backend env template.
# Copy to `.env` and fill in secrets. `.env` is gitignored.

# --- LLM providers ---
ANTHROPIC_API_KEY=
SERPAPI_API_KEY=
# Google Maps API key for MAPS_PROVIDER=google_places (Places API New).
# Setup checklist (all steps required before the key will work):
#   1. Create/select a GCP project at https://console.cloud.google.com
#   2. Enable billing — Google requires a payment method even for the free tier.
#      Without it, API calls fail with PERMISSION_DENIED regardless of quota.
#   3. Enable "Places API (New)" under APIs & Services → Library.
#      (Not "Places API" — that is the legacy API, closed to new projects.)
#   4. Create an API key under APIs & Services → Credentials.
#   5. IMPORTANT: Set a per-API quota to cap spend.
#      APIs & Services → Quotas → "Places API (New)" → set a daily limit on
#      "Text Search Requests Per Day". Google has NO default hard cap — without
#      a quota, a bug can spend without bound. A budget alert is NOT a cap.
#      See docs/cost-guardrails.md for the full defense-in-depth writeup.
GOOGLE_MAPS_API_KEY=

# --- Fallback LLM providers ---
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Langfuse (self-hosted, docker-compose runs it on port 3030) ---
# Generate LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY in the Langfuse UI
# (http://localhost:3030) after the stack is up for the first time,
# then paste them here and restart api-gateway + ai-worker.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=http://localhost:3030

# Container-side secrets — generate each with: openssl rand -hex 32
# Set once; changing them after Langfuse has data invalidates sessions.
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# Set to "1" to skip all telemetry setup (CI, unit tests, offline dev).
# Langfuse also silently disables itself when keys are absent.
# LANGFUSE_DISABLED=1

# --- Optional Langfuse internals (docker-compose has safe defaults) ---
# LANGFUSE_MINIO_ROOT_PASSWORD=miniosecret
# LANGFUSE_REDIS_AUTH=langfuse-redis-dev
# LANGFUSE_CLICKHOUSE_USER=clickhouse
# LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse

# --- Temporal ---
TEMPORAL_ADDRESS=localhost:7233

# --- App ---
# SQLite used for SerpAPI local cache (maps_bridge)
DATABASE_URL=sqlite:///./lead-forge.db
# Postgres used by api_gateway (SQLAlchemy) — asyncpg driver format
APP_DATABASE_URL=postgresql+asyncpg://temporal:temporal@localhost:5432/temporal
# Postgres used by frontend (Prisma) — standard postgresql format
PRISMA_DATABASE_URL=postgresql://temporal:temporal@localhost:5432/temporal
# Backend base URL for the Next.js API client (default: local FastAPI)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Local docker-compose sets PORT=8000 on api-gateway (Cloud Run uses 8080 via its own inject).
# PORT=8000
MAPS_PROVIDER=mock
# MAPS_TRANSPORT controls how ai_worker reaches maps_bridge:
#   stdio   — subprocess via MCP stdio (default, local dev/compose)
#   inline  — in-process module call (Cloud Run: no stdio sidecars)
MAPS_TRANSPORT=stdio
# Hard ceiling on search pagination (pages, not leads). Each page is up to 20
# results, so the default caps any single search at 100 results regardless of
# the requested limit. Raising this multiplies Place Details calls 1:1 — see
# docs/cost-guardrails.md ("Pagination cost multiplier") before changing it.
MAPS_MAX_PAGES=5

# --- Demo mode (abuse protection for public deployments) ---
# Set DEMO_MODE=true to enable global run cap + per-IP request rate limiting.
# Leave false (default) for local forks — no limits, no Redis calls.
DEMO_MODE=false
DEMO_MAX_RUNS_PER_DAY=20
DEMO_MAX_REQUESTS_PER_MINUTE=30
# Redis for rate-limit counters (shared with Langfuse in docker-compose).
REDIS_URL=redis://:langfuse-redis-dev@localhost:6379

# --- Execution mode (demo vs full-stack) ---
# EXECUTION_MODE=temporal   # "sync" for the live demo (no Temporal, results inline)
# PERSISTENCE_ENABLED=true  # false in the live demo (no DB writes, no history)
# RATE_LIMIT_BACKEND=redis  # "memory" in the live demo (no Redis needed)
# DEMO_MAX_LEADS_SYNC=25    # cap for sync execution path to prevent Cloud Run timeout
# Frontend also reads PERSISTENCE_ENABLED (server-side) to show/hide history.
# Set to false in the Cloud Run frontend container for the live demo.
